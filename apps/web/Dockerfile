FROM oven/bun:alpine AS base

FROM base AS pruner

WORKDIR /app

COPY apps/web/package.json apps/web/package.json
COPY packages/env/package.json packages/env/package.json
COPY packages/ui/package.json packages/ui/package.json
COPY package.json package.json

WORKDIR /app/apps/web

FROM base AS builder

WORKDIR /app

ARG FREESOUND_CLIENT_ID
ARG FREESOUND_API_KEY

COPY package.json package.json
COPY bun.lock bun.lock
COPY turbo.json turbo.json

COPY apps/web/package.json apps/web/package.json
COPY packages/env/package.json packages/env/package.json
COPY packages/ui/package.json packages/ui/package.json

RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --ignore-scripts --no-optional && \
    cd /app && \
    sed -i '/@napi-rs\/canvas\|onnxruntime-node/d' apps/web/package.json && \
    bun install --no-optional

COPY apps/web/ apps/web/
COPY packages/env/ packages/env/
COPY packages/ui/ packages/ui/

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

ENV DATABASE_URL="postgresql://opencut:opencut@localhost:5432/opencut"
ENV BETTER_AUTH_SECRET="build-time-secret"
ENV UPSTASH_REDIS_REST_URL="http://localhost:8079"
ENV UPSTASH_REDIS_REST_TOKEN="example_token"
ENV NEXT_PUBLIC_SITE_URL="http://144.91.91.227:3101"
ENV NEXT_PUBLIC_MARBLE_API_URL="https://api.marblecms.com"
ENV NEXT_PUBLIC_AI_BACKEND_URL="http://144.91.91.227:8420"
ENV NEXT_PUBLIC_WHISPER_SERVICE_URL="http://144.91.91.227:8421"
ENV NEXT_PUBLIC_TTS_SERVICE_URL="http://144.91.91.227:8422"
ENV NEXT_PUBLIC_IMAGE_SERVICE_URL="http://144.91.91.227:8423"

ENV FREESOUND_CLIENT_ID=$FREESOUND_CLIENT_ID
ENV FREESOUND_API_KEY=$FREESOUND_API_KEY

WORKDIR /app/apps/web
RUN --mount=type=cache,target=/app/apps/web/.next/cache \
    bun run build

FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "apps/web/server.js"]
